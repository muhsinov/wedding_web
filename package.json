{
  "name": "wedding_web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/materialize-assets.mjs",
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/materialize-assets.mjs",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "postinstall": "node scripts/materialize-assets.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.8",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.468.0",
    "next": "^15.5.21",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.35.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.21",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "$postcss",
    "sharp": "$sharp"
  }
}
